# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# --- Site ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=GADGET//WIRE

# --- Ingestion ---
# Long random string. Required on /api/ingest as ?token= or x-ingest-token header.
INGEST_TOKEN=replace-with-long-random-string

# Vercel Cron auth header (set as CRON_SECRET on Vercel; default cron uses Authorization header)
CRON_SECRET=replace-with-long-random-string

# Optional: timezone label used in admin
ADMIN_TZ=Asia/Tokyo
